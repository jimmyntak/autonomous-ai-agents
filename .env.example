# OpenAI API Key
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Discord Bot Token (used in bladebet.js and pc-statbot)
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Discord Bot Token 2 (used in config.json for main bot)
DISCORD_BOT_TOKEN_2=YOUR_DISCORD_BOT_TOKEN_2_HERE

# Stoiximan login credentials (used in Stoiximan.js)
STOIXIMAN_USERNAME=YOUR_STOIXIMAN_USERNAME_HERE
STOIXIMAN_PASSWORD=YOUR_STOIXIMAN_PASSWORD_HERE

# Novibet login credentials (used in config.json)
NOVIBET_USERNAME=YOUR_NOVIBET_USERNAME_HERE
NOVIBET_PASSWORD=YOUR_NOVIBET_PASSWORD_HERE
